  hero: { background: "#ffffff", border: "1px solid #e2e8f0", borderRadius: 24, padding: 24, display: "flex", justifyContent: "space-between", alignItems: "flex-start", gap: 18, boxShadow: "0 16px 36px rgba(15,23,42,.06)" },
